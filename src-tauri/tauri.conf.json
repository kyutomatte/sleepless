{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sleepless",
  "version": "0.1.2",
  "identifier": "app.mac.sleepless",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build && pnpm build:helper",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sleepless",
        "width": 520,
        "height": 700,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "helper/target/release/sleepless-pmset-helper": "sleepless-pmset-helper"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
